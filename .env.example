# Required: your Anthropic API key (Boa forwards requests on your behalf)
ANTHROPIC_API_KEY=

# Required: OpenAI API key for text-embedding-3-small embeddings
OPENAI_API_KEY=

# Required: PostgreSQL connection string with pgvector extension enabled
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: port for the Boa proxy server (default: 3333)
PORT=3333

# minimum number of unique authors who must independently capture a fact before it can be promoted to CLAUDE.md
PROMOTE_THRESHOLD=2
